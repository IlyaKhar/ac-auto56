  "definitions": {
    "Any": {
      "type": "object",
      "description": "Структура см. фактический JSON ответа API"
    },
    "ErrorBody": {
      "type": "object",
      "properties": { "error": { "type": "string" } }
    },
    "HealthBody": {
      "type": "object",
      "properties": { "status": { "type": "string", "example": "ok" } }
    },
    "TokenPair": {
      "type": "object",
      "properties": {
        "access_token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "token_type": { "type": "string" },
        "expires_in": { "type": "integer", "format": "int32" }
      }
    },
    "LoginRequest": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "RefreshRequest": {
      "type": "object",
      "properties": { "refresh_token": { "type": "string" } }
    },
    "MeResponse": {
      "type": "object",
      "properties": {
        "user_id": { "type": "integer", "format": "int64" },
        "role": { "type": "string" }
      }
    },
    "CreateApplicationRequest": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "car_brand": { "type": "string" },
        "vin": { "type": "string" },
        "service_id": { "type": "integer", "format": "int64" },
        "message": { "type": "string" },
        "turnstile_token": { "type": "string" }
      }
    },
    "IDResponse": {
      "type": "object",
      "properties": { "id": { "type": "integer", "format": "int64" } }
    },
    "StaffPing": {
      "type": "object",
      "properties": { "staff": { "type": "boolean" } }
    },
    "AdminPing": {
      "type": "object",
      "properties": { "admin": { "type": "boolean" } }
    },
    "ReorderIDs": {
      "type": "object",
      "required": ["ids"],
      "properties": {
        "ids": {
          "type": "array",
          "items": { "type": "integer", "format": "int64" }
        }
      }
    },
    "PatchApplicationStaff": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "assigned_manager_id": { "type": "integer", "format": "int64" },
        "clear_assigned": { "type": "boolean" }
      }
    },
    "CommentBody": {
      "type": "object",
      "required": ["body"],
      "properties": { "body": { "type": "string" } }
    },
    "CreateUserRequest": {
      "type": "object",
      "required": ["email", "password", "role"],
      "properties": {
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["moderator", "admin"] }
      }
    },
    "PatchUserRequest": {
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "is_active": { "type": "boolean" }
      }
    },
    "ResetPasswordRequest": {
      "type": "object",
      "required": ["password"],
      "properties": { "password": { "type": "string" } }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Формат: Bearer {access_token}"
    }
  }
}
