# Сборка из корня: docker build -f server/Dockerfile.seed -t ac-seed .
FROM golang:1.22-alpine AS build
WORKDIR /src
COPY server/ ./
RUN go mod tidy && CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/seed ./cmd/seed

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /out/seed /seed
ENTRYPOINT ["/seed"]
