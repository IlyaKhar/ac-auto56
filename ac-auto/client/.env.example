# Только для npm run dev на машине (не для контейнера client).
# Docker Compose берёт VITE_* из корневого .env или дефолтов в docker-compose.yml.
#
# Шапка и футер БЕЗ API (дефолт): не ставь true или закомментируй — меню/футер не запрашиваются, не «слетает» без бэка.
# В Docker по умолчанию включено подтягивание из CMS (см. docker-compose.yml).
# VITE_LAYOUT_FROM_API=true

# VITE_API_URL=http://localhost:8080
# VITE_TURNSTILE_SITE_KEY=
# Текст в шапке (логотип-ряд), по умолчанию «AC AUTO»
# VITE_SITE_BRAND=AC AUTO
# Модалка «Не нашли авто»: задержка (мс), выключить, свой URL картинки шапки
# VITE_LEAD_MODAL_DELAY_MS=10000
# VITE_LEAD_MODAL_DISABLED=false
# VITE_LEAD_MODAL_IMAGE_URL=
# Герой /katalog и модалка «Узнать подробнее» (или положи katalog-hero-man.png и trade-modal-header.png в public/)
# VITE_KATALOG_HERO_IMAGE=
# Герой /avtomobili: фон (URL или путь), иначе public/avtomobili-hero.jpg; цвет нижней полосы (#hex)
# VITE_AVTOBILI_HERO_IMAGE=
# VITE_AVTOBILI_HERO_ACCENT=#e30613
# VITE_TRADE_MODAL_IMAGE=
# Логотип поверх фото в карточке каталога (URL или путь от корня сайта, напр. catalog-logo.png в public/)
# VITE_CATALOG_CARD_LOGO_URL=
# Логотип шапки: public/logo-car-icon.svg — лучше один широкий lockup (машина + текст), без дубля слогана.
# Если лого только значок — включи текст справа: VITE_HEADER_EXTRA_TAGLINE=true
# VITE_HEADER_EXTRA_TAGLINE=false
# VITE_HEADER_SLOGAN_1=СЕТЬ САЛОНОВ
# VITE_HEADER_SLOGAN_2=АВТОМОБИЛЕЙ С ПРОБЕГОМ
# Телефон в шапке, если в меню нет пункта с tel: (можно tel:+79619429992)
# VITE_PUBLIC_PHONE_TEL=tel:+79619429992
# VITE_PUBLIC_PHONE_LABEL=По любым вопросам
# Футер: второй телефон, соцсети
# VITE_FOOTER_PHONE2_DISPLAY=+7 (903) 398-88-11
# VITE_FOOTER_PHONE2_TEL=tel:+79033988811
# VITE_SOCIAL_VK=https://vk.com/...
# VITE_SOCIAL_YOUTUBE=https://youtube.com/...
# Плавающие кнопки (правый нижний угол)
# VITE_FLOAT_TELEGRAM=https://t.me/ACTAuto56
# VITE_FLOAT_WHATSAPP=https://wa.me/79228521329
# VITE_FLOAT_TEL=tel:+79619429992
