# Локальный запуск API с хоста (go run) или подстановка в docker compose для ${VAR}.
# Docker-сервис api сам подставляет DATABASE_URL=@postgres и MIGRATIONS_PATH=/migrations.

# API (локально)
DATABASE_URL=postgres://acauto:acauto@localhost:5432/acauto?sslmode=disable
HTTP_PORT=8080
MIGRATIONS_PATH=./database/migrations
CORS_ALLOW_ORIGIN=http://localhost:5173

# Vite в Docker: compose подставляет в сервис client (локальный npm run dev — см. client/.env)
# VITE_API_URL=http://localhost:8080
# VITE_TURNSTILE_SITE_KEY=

# JWT (access по умолчанию 15 мин, refresh 7 дней — см. config)
JWT_SECRET=change-me-at-least-16-chars
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# Cloudflare Turnstile (в проде обязательно; локально можно TURNSTILE_SKIP=true)
TURNSTILE_SECRET_KEY=
TURNSTILE_SKIP=true

# Telegram: новые заявки с сайта в чат (токен @BotFather, chat_id из getUpdates)
# В .env для Docker лучше в кавычках — иначе минус у chat_id ломает разбор
# TELEGRAM_BOT_TOKEN="123:ABC..."
# TELEGRAM_CHAT_ID="-1001234567890"

# Admin/moderator: автосоздание при docker compose up (bootstrap) и ручной seed
# Дефолты в compose: admin@local.test / dev-AdminPass-change-me
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=dev-AdminPass-change-me
# MODERATOR_EMAIL=mod@example.com
# MODERATOR_PASSWORD=change-me-mod
