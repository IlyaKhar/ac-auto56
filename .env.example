# API
DATABASE_URL=postgres://acauto:acauto@localhost:5432/acauto?sslmode=disable
HTTP_PORT=8080
MIGRATIONS_PATH=./database/migrations
CORS_ALLOW_ORIGIN=http://localhost:5173

# JWT (access по умолчанию 15 мин, refresh 7 дней — см. config)
JWT_SECRET=change-me-at-least-16-chars
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# Cloudflare Turnstile (в проде обязательно; локально можно TURNSTILE_SKIP=true)
TURNSTILE_SECRET_KEY=
TURNSTILE_SKIP=true

# Seed пользователей (docker compose --profile seed run --rm seed)
# Нужна хотя бы одна полная пара: ADMIN_* и/или MODERATOR_*
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# MODERATOR_EMAIL=mod@example.com
# MODERATOR_PASSWORD=change-me-mod
